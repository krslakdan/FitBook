# FitBook local development configuration
# Copy this file to .env and replace placeholder values.

ASPNETCORE_ENVIRONMENT=Development

# Host ports (local F5 uses launchSettings port 5147; Docker API uses 5121 via docker-compose)
API_HOST_PORT=5121
SQL_HOST_PORT=1435
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# SQL Server
ACCEPT_EULA=Y
SQLSERVER_IMAGE=mcr.microsoft.com/mssql/server:2022-CU13-ubuntu-22.04
MSSQL_SA_PASSWORD=YOUR_SQL_PASSWORD

# Local dotnet run / EF update-database: use localhost and SQL_HOST_PORT.
# Docker API overrides this with fitbook-db via docker-compose.yml.
ConnectionStrings__DefaultConnection=Server=localhost,1435;Database=230163;User Id=sa;Password=YOUR_SQL_PASSWORD;TrustServerCertificate=True;Encrypt=False;

# JWT
JwtToken__SecretKey=YOUR_RANDOM_SECRET_KEY
JwtToken__Issuer=FitBook
JwtToken__Audience=FitBookApp
JwtToken__ExpirationMinutes=15

# Refresh Token
RefreshToken__ExpirationDays=7

# CORS
Cors__AllowedOrigins=http://localhost:5121

# RabbitMQ
# Local dotnet run: use localhost (RABBITMQ_PORT is published to the host).
# Docker API/Worker containers override this with fitbook-rabbitmq via docker-compose.yml.
RabbitMQ__Host=localhost
RabbitMQ__Port=5672
RabbitMQ__Username=guest
RabbitMQ__Password=guest
RabbitMQ__NotificationQueue=fitbook.notifications

# Stripe (sandbox)
Stripe__SecretKey=YOUR_STRIPE_SECRET_KEY
Stripe__WebhookSecret=YOUR_STRIPE_WEBHOOK_SECRET

# SMTP
SMTP__Host=smtp.gmail.com
SMTP__Port=587
SMTP__Username=YOUR_EMAIL
SMTP__Password=YOUR_EMAIL_PASSWORD
SMTP__UseSsl=true