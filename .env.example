# FitBook local development configuration.
# Copy this file to .env and keep .env out of git.

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5121

API_HOST_PORT=5121
SQL_HOST_PORT=1435
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

ACCEPT_EULA=Y
SQLSERVER_IMAGE=mcr.microsoft.com/mssql/server:2022-CU13-ubuntu-22.04
MSSQL_SA_PASSWORD=FitBook_230163!
ConnectionStrings__DefaultConnection=Server=fitbook-db;Database=230163;User Id=sa;Password=FitBook_230163!;TrustServerCertificate=True;Encrypt=False;

JwtToken__SecretKey=replace-with-a-long-random-secret
JwtToken__Issuer=FitBook
JwtToken__Audience=FitBookApp

Cors__AllowedOrigins=http://localhost:5121

RabbitMQ__Host=fitbook-rabbitmq
RabbitMQ__Port=5672
RabbitMQ__Username=guest
RabbitMQ__Password=guest
RabbitMQ__NotificationQueue=fitbook.notifications

Stripe__SecretKey=sk_test_replace_me
Stripe__WebhookSecret=whsec_replace_me

SMTP__Host=smtp.gmail.com
SMTP__Port=587
SMTP__Username=replace-me@example.com
SMTP__Password=replace-me
SMTP__UseSsl=true
